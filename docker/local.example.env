# Пример переменных для приложений на хосте рядом с локальным стеком Compose.
# Скопируйте в .env или подставьте в конфиг; значения — плейсхолдеры, без реальных секретов.
# Фактические учётные данные см. в docker-compose.yml (секции environment).

# --- PostgreSQL (с хоста к опубликованному порту) ---
ZCH_LOCAL_POSTGRES_HOST=localhost
ZCH_LOCAL_POSTGRES_PORT=5432
ZCH_LOCAL_POSTGRES_USER=CHANGE_ME
ZCH_LOCAL_POSTGRES_PASSWORD=CHANGE_ME
ZCH_LOCAL_POSTGRES_DB=CHANGE_ME

# Из другого контейнера в той же сети: хост postgres, порт 5432 (см. docs/docker-local.md).

# --- Redis ---
ZCH_LOCAL_REDIS_HOST=localhost
ZCH_LOCAL_REDIS_PORT=6379

# --- MinIO (S3-совместимый API) ---
ZCH_LOCAL_MINIO_ENDPOINT=http://localhost:9000
ZCH_LOCAL_MINIO_CONSOLE=http://localhost:9001
ZCH_LOCAL_MINIO_ACCESS_KEY=CHANGE_ME
ZCH_LOCAL_MINIO_SECRET_KEY=CHANGE_ME
ZCH_LOCAL_MINIO_BUCKET_KEYBOARDS=keyboards
ZCH_LOCAL_MINIO_BUCKET_PARTS=parts

# --- OIDC / Auth (публичный URL за Traefik при оверлее docker-compose.local.yml) ---
# ZCH_LOCAL_AUTH_ISSUER=http://auth.localhost:8080
