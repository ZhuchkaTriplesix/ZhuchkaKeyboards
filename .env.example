# Скопируйте в `.env` в корне репозитория (файл `.env` в git не коммитится).
# Секреты не вставляйте в config.ini и не публикуйте в чатах.

TELEGRAM_BOT_TOKEN=
# Имя бота без @ — для сборки витрины (Telegram Login iframe).
TELEGRAM_BOT_USERNAME=ZhuchkaKeyboards_bot

# Опционально: базовый URL auth для Flutter web в Docker (build-arg market_web / system_web).
# По умолчанию в docker-compose.local.yml — http://auth.localtest.me (маршрут Traefik auth-localtest).
# Если пользуетесь только Traefik на порту 8080 и порт 80 закрыт: MARKET_AUTH_BASE_URL=http://auth.localtest.me:8080
# MARKET_AUTH_BASE_URL=
# SYSTEM_AUTH_BASE_URL=
